
&НаСервере
Процедура ЗаполнитьНаСервере()
	ОбработкуВОбъект = РеквизитФормыВЗначение("Объект");
	Объект.Накладные.Загрузить(ОбработкуВОбъект.ВернутьНакладные());
КонецПроцедуры

&НаКлиенте
Процедура Заполнить(Команда)
	ЗаполнитьНаСервере();
	//ну хоть один кооментарий
	Клиент="GE";
КонецПроцедуры

&НаСервере
Процедура ОчиститьНаСервере()
	Объект.Накладные.Очистить();
КонецПроцедуры

&НаКлиенте
Процедура Очистить(Команда)
	ОчиститьНаСервере();
КонецПроцедуры
